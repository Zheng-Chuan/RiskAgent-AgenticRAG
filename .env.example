# RiskAgent-AgenticRAG Configuration
# Copy this file to .env and fill in the values

# Project Configuration
PROJECT_NAME=RiskAgent-AgenticRAG

# LLM Configuration (火山引擎 Coding API)
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=ark-code-latest

# OpenRouter Configuration (optional)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# Milvus Configuration
MILVUS_URI=
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_SECURE=false
MILVUS_COLLECTION=riskagent_agenticrag
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_METRIC=L2
MILVUS_NLIST=128
MILVUS_NPROBE=16
MILVUS_WAIT_READY=true
MILVUS_HEALTH_PORT=9091
MILVUS_READY_TIMEOUT_S=120
MILVUS_CONSISTENCY=Session
RISKAGENT_USE_DOCKER_MILVUS=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=riskagent
REDIS_DB=0
REDIS_URL=redis://:riskagent@localhost:6379/0

# Embeddings Configuration
EMBEDDINGS_PROVIDER=hf
EMBEDDINGS_MODEL=BAAI/bge-large-zh-v1.5

# Paths Configuration
RISKAGENT_CORPUS_DIR=corpus
RISKAGENT_PERSIST_DIR=.milvus

# Feature Flags
USE_LANGGRAPH=true
RISKAGENT_SELF_RAG=true
RISKAGENT_ENABLE_QUERY_INTEL=true
RISKAGENT_RETRIEVER_MODE=step2

# Prompt Configuration
RISKAGENT_PROMPT_VERSION=v1

# Tracing Configuration
RISKAGENT_TRACE_SNIPPET_CHARS=240

# LangSmith Configuration (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=RiskAgent-AgenticRAG

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# API Authentication
API_KEY_ENABLED=true
API_KEY_SECRET=your-api-key-secret-here

# Hugging Face Configuration
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# ──────────────────────────────────────────────
# LLM Governance / Traffic Management
# ──────────────────────────────────────────────
# Token Bucket Rate Limiting
LLM_GOVERNANCE_RATE_LIMIT_TOKENS_PER_MIN=60000
LLM_GOVERNANCE_RATE_LIMIT_TOKENS_PER_MIN_NON_CRITICAL=8000
LLM_GOVERNANCE_BURST_TOKENS=0
LLM_GOVERNANCE_BURST_TOKENS_NON_CRITICAL=0

# Token Alert Thresholds
LLM_GOVERNANCE_TOKEN_ALERT_HOURLY=100000
LLM_GOVERNANCE_TOKEN_ALERT_DAILY=2000000

# Retry Configuration
LLM_GOVERNANCE_MAX_RETRIES=3
LLM_GOVERNANCE_RETRY_BACKOFF_BASE=1.0

# Timeout Configuration (seconds)
LLM_GOVERNANCE_TIMEOUT_TOTAL=120
LLM_GOVERNANCE_TIMEOUT_CONNECT=10
LLM_GOVERNANCE_TIMEOUT_READ=90

# Cache Configuration
LLM_GOVERNANCE_CACHE_ENABLED=true
LLM_GOVERNANCE_CACHE_MAX_SIZE=1000

# Concurrency Limit
LLM_GOVERNANCE_MAX_CONCURRENT_REQUESTS=10
