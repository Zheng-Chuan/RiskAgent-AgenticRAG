  {
    "id": "q31",
    "qrels": [
      {
        "qrel_id": "q31_r1",
        "text": "Theta is the sensitivity of a derivative's value to the passage of time.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q32",
    "qrels": [
      {
        "qrel_id": "q32_r1",
        "text": "Rho is the sensitivity of a derivative's value to changes in interest rates.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q33",
    "qrels": [
      {
        "qrel_id": "q33_r1",
        "text": "Volga is the sensitivity of Vega to changes in implied volatility (second-order Greek).",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q34",
    "qrels": [
      {
        "qrel_id": "q34_r1",
        "text": "Vanna is the sensitivity of Delta to changes in implied volatility, or sensitivity of Vega to changes in underlying price.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q35",
    "qrels": [
      {
        "qrel_id": "q35_r1",
        "text": "Charm is the sensitivity of Delta to the passage of time.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q36",
    "qrels": [
      {
        "qrel_id": "q36_r1",
        "text": "Historical volatility is based on past price movements, while implied volatility is the market's expectation of future volatility, derived from option prices.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q37",
    "qrels": [
      {
        "qrel_id": "q37_r1",
        "text": "A delta-neutral portfolio has a total delta of zero, meaning it is insensitive to small changes in the underlying price.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q38",
    "qrels": [
      {
        "qrel_id": "q38_r1",
        "text": "Gamma hedging adjusts a portfolio to reduce gamma, making it more stable to larger moves in the underlying.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q39",
    "qrels": [
      {
        "qrel_id": "q39_r1",
        "text": "Volatility skew is the pattern where implied volatility varies across strike prices, typically with lower strikes having higher volatility.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q40",
    "qrels": [
      {
        "qrel_id": "q40_r1",
        "text": "Volatility smile is a pattern where both out-of-the-money and in-the-money options have higher implied volatility than at-the-money options.",
        "relevance": 2
      }
    ]
  },
  {
    "id": "q41",
    "qrels": [
      {
